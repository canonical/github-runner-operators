          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Memory Usage",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "expr": "100 * (1 - (system_memory_usage_bytes{state=\"free\",github_runner=~\"$github_runner\",github_job=~\"$github_job\",github_repository=~\"$github_repository\"} / sum without (state) (system_memory_usage_bytes{github_runner=~\"$github_runner\",github_job=~\"$github_job\",github_repository=~\"$github_repository\"})))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "fieldConfig": {
        "defaults": {
